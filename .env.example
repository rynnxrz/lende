# openrental — environment variables example
# Copy to .env.local for local dev. In Vercel, set these via Project Settings → Environment Variables.
# Mark NEXT_PUBLIC_* as exposed-to-browser; everything else server-only.
# Required vs optional flagged below. Source of truth = grep `process.env.` in src/.

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (REQUIRED) — auth + DB + storage
# ─────────────────────────────────────────────────────────────────────────────
# Public project URL — used by browser client + server.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Public anon key — RLS-bound, safe to expose.
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
# Service role key — BYPASSES RLS. Server-only. Never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=ey...

# ─────────────────────────────────────────────────────────────────────────────
# Email — Resend (REQUIRED for transactional emails: approval / shipping / verification / new request)
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Where to route inbound admin notification emails (bulk request submissions etc.). Server-only.
ADMIN_NOTIFY_EMAIL=ivy@example.com

# ─────────────────────────────────────────────────────────────────────────────
# Public site config (OPTIONAL — falls back to placeholder)
# ─────────────────────────────────────────────────────────────────────────────
# Customer-facing contact email shown in footer / etc.
NEXT_PUBLIC_CONTACT_EMAIL=ivy@example.com

# ─────────────────────────────────────────────────────────────────────────────
# Brand identity (OPTIONAL — defaults to 'lende' / D1 product name)
# Set these for the legacy single-tenant deployment to render its studio brand.
# Read by src/lib/constants/brand.ts. Multi-tenancy (BRIEF-03) will replace
# these with per-org context loaded from organizations table + JWT claims.
# ─────────────────────────────────────────────────────────────────────────────
# Display name (e.g. "Ivy J Studio"). Default: 'lende'
NEXT_PUBLIC_BRAND_NAME=
# All-caps variant for legal headings (e.g. "IVY J STUDIO"). Default: 'LENDE'
NEXT_PUBLIC_BRAND_NAME_UPPER=
# Instagram handle, no leading @ (e.g. "ivyjstudio"). Default: 'lende'
NEXT_PUBLIC_BRAND_INSTAGRAM=
# Brand contact email — falls back to NEXT_PUBLIC_CONTACT_EMAIL if unset.
NEXT_PUBLIC_BRAND_CONTACT_EMAIL=
# Domain for Smart Import website-match (Shopify search endpoint).
# Optional — leave blank to skip the website-match step.
NEXT_PUBLIC_BRAND_PRODUCT_LOOKUP_DOMAIN=
# Customer-service AI persona name (e.g. "Ivy"). Default: 'the studio assistant'
NEXT_PUBLIC_BRAND_CONCIERGE_NAME=
# Postal address lines for legal documents — pipe-delimited.
# Example: "334 Queenstown Rd|London|SW11 8NP"
NEXT_PUBLIC_BRAND_ADDRESS_LINES=
# Studio phone number for legal documents.
NEXT_PUBLIC_BRAND_PHONE=

# ─────────────────────────────────────────────────────────────────────────────
# AI providers — Smart Import / OCR / chat (OPTIONAL: only set what you use)
# Pick one primary provider via AI_PROVIDER. Adapters auto-pick API key based on provider.
# ─────────────────────────────────────────────────────────────────────────────
# Primary chat / vision provider: 'gemini' | 'dashscope' | 'qwen' | 'ollama'
AI_PROVIDER=gemini
AI_MODEL=
AI_BASE_URL=
# Optional fallback provider (kicks in only if AI_ALLOW_FALLBACK=true)
AI_ALLOW_FALLBACK=false
AI_FALLBACK_PROVIDER=
AI_FALLBACK_MODEL=
AI_FALLBACK_BASE_URL=

# Document OCR provider: 'glm-ocr' | 'zai' | (other adapters)
DOCUMENT_AI_PROVIDER=
DOCUMENT_AI_MODEL=
DOCUMENT_AI_BASE_URL=

# Legacy provider aliases (read by src/lib/ai/settings.ts) — leave blank if AI_* set
LOOKBOOK_LLM_PROVIDER=
LOOKBOOK_LLM_MODEL=
LOOKBOOK_DOCUMENT_PROVIDER=

# ─── Provider-specific API keys (set only the ones you use) ───
# Google Gemini (any one of the three is read in priority order)
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_API_KEY=

# Alibaba Dashscope / Qwen (either var works)
DASHSCOPE_API_KEY=
QWEN_API_KEY=
DASHSCOPE_BASE_URL=
QWEN_BASE_URL=

# Zhipu AI / GLM (either var works)
ZAI_API_KEY=
GLM_OCR_API_KEY=
GLM_OCR_BASE_URL=
GLM_OCR_MODEL=

# Ollama (self-hosted) — only if AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Customer-Service feature flags (OPTIONAL — staged rollout switches)
# Truthy = "1" | "true" | "yes" | "on" (see src/lib/customer-service/feature-flags.ts)
# ─────────────────────────────────────────────────────────────────────────────
CS_TRACK_A_ONLY=
CS_DISABLE_SENSITIVE_AUTO_EXECUTE=
CS_FORCE_SENSITIVE_FACTS_ONLY=

# ─────────────────────────────────────────────────────────────────────────────
# Sentry (REQUIRED for error tracking + performance monitoring)
# ─────────────────────────────────────────────────────────────────────────────
# Public DSN — used by browser client. Safe to expose.
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# Server-side DSN (same value as above, but server-only env var for clarity).
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# Org slug from Sentry dashboard.
SENTRY_ORG=your-org
# Project slug from Sentry dashboard.
SENTRY_PROJECT=lende
# Auth token for source-map uploads during build. Server-only.
SENTRY_AUTH_TOKEN=sntrys_...

# ─────────────────────────────────────────────────────────────────────────────
# Vercel-injected (DO NOT SET MANUALLY — Vercel sets these automatically)
# ─────────────────────────────────────────────────────────────────────────────
# NODE_ENV — set by Next.js / Vercel
# VERCEL_URL / VERCEL_ENV — set by Vercel for branch-aware logic
