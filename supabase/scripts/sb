#!/usr/bin/env bash
# sb — quick Supabase debug helper for the `lende` project.
#
# Loads credentials from .env.local at the repo root and talks to the live
# project over HTTPS (PostgREST) using the service-role key. No DB password
# needed for table reads/writes and RPC calls. Raw SQL needs SUPABASE_DB_URL
# (the pooler connection string from the dashboard) — see `sb sql` below.
#
# Usage:
#   sb tables                         List all tables exposed by PostgREST
#   sb get <table> [pgrst-query]      Select rows, e.g. sb get items 'select=id,name&limit=5'
#   sb count <table> [filter]         Count rows, e.g. sb count reservations 'status=eq.pending'
#   sb rpc <fn> ['{"arg":1}']         Call a Postgres function (RPC)
#   sb sql <file.sql | "SELECT ...">  Run raw SQL via psql (requires SUPABASE_DB_URL)
#
# All output is pretty-printed JSON where applicable.

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
ENV_FILE="$ROOT/.env.local"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "error: $ENV_FILE not found" >&2; exit 1
fi
set -a; . "$ENV_FILE"; set +a

URL="${NEXT_PUBLIC_SUPABASE_URL:?NEXT_PUBLIC_SUPABASE_URL missing}"
KEY="${SUPABASE_SERVICE_ROLE_KEY:?SUPABASE_SERVICE_ROLE_KEY missing}"

pp() { python3 -m json.tool 2>/dev/null || cat; }

req() { # method path [extra curl args...]
  local method="$1" path="$2"; shift 2
  curl -s -X "$method" "${URL}/rest/v1/${path}" \
    -H "apikey: ${KEY}" \
    -H "Authorization: Bearer ${KEY}" \
    -H "Content-Type: application/json" "$@"
}

cmd="${1:-help}"; shift || true

case "$cmd" in
  tables)
    req GET "" \
      | python3 -c "import sys,json;d=json.load(sys.stdin);print('\n'.join(sorted(d.get('definitions',{}).keys())))"
    ;;
  get)
    table="${1:?usage: sb get <table> [pgrst-query]}"; q="${2:-}"
    req GET "${table}${q:+?$q}" | pp
    ;;
  count)
    table="${1:?usage: sb count <table> [filter]}"; filter="${2:-}"
    req GET "${table}${filter:+?$filter}" \
      -H "Prefer: count=exact" -H "Range: 0-0" -I \
      | grep -i content-range || true
    ;;
  rpc)
    fn="${1:?usage: sb rpc <fn> [json-args]}"; body="${2:-{}}"
    req POST "rpc/${fn}" -d "$body" | pp
    ;;
  sql)
    arg="${1:?usage: sb sql <file.sql | \"SELECT ...\">}"
    if [[ -z "${SUPABASE_DB_URL:-}" ]]; then
      echo "error: SUPABASE_DB_URL not set." >&2
      echo "  Get the pooler URI from the dashboard: Project Settings → Database →" >&2
      echo "  Connection string → URI (Transaction pooler), then add to .env.local:" >&2
      echo "    SUPABASE_DB_URL=postgresql://postgres.zigyiqqboiadinelfzxw:<PW>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres" >&2
      exit 1
    fi
    if [[ -f "$arg" ]]; then psql "$SUPABASE_DB_URL" -f "$arg"; else psql "$SUPABASE_DB_URL" -c "$arg"; fi
    ;;
  help|*)
    sed -n '2,20p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
    ;;
esac
