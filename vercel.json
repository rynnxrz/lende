{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "regions": ["sin1"],
  "github": {
    "silent": false
  },
  "crons": [
    {
      "path": "/api/cron/onboarding-emails",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 21 * * 4"
    }
  ]
}
